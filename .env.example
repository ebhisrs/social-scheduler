# === DATABASE (Neon PostgreSQL for Vercel) ===
# Get from neon.tech → your project → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
# Use the "Direct connection" string for DIRECT_URL
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# === LOCAL DEV (SQLite) ===
# Comment out the two lines above and uncomment below for local dev:
# DATABASE_URL="file:./dev.db"

# === AI ===
GEMINI_API_KEY="AIza..."

# === CRON ===
CRON_SECRET="your-random-secret-string"
CRON_WINDOW_MINUTES=2

# === EMAIL ALERTS (optional, Mailtrap) ===
SMTP_HOST="live.smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER="api"
SMTP_PASS="your-mailtrap-token"
SMTP_FROM="noreply@yourdomain.com"
